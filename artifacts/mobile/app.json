{
  "expo": {
    "name": "rubai - AI Goal Coach",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#15140F"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.rubai.mobile"
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "package": "com.rubai.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#15140F"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Feather.ttf",
            "./assets/fonts/Ionicons.ttf",
            "./assets/fonts/MaterialIcons.ttf"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow rubai to use your microphone so you can talk to your coach."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow rubai to use your camera so you can snap what you're working on and ask the coach about it.",
          "photosPermission": "Allow rubai to read your photos so you can share screenshots and reference images with the coach."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#84CC16"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow rubai to read your events so the AI can plan around your meetings.",
          "remindersPermission": "Allow rubai to read your reminders so the AI can incorporate them into your daily plan."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
