# =============================================================================
# rubai — shared environment (copy to `.env` at repo root)
# =============================================================================
# Used by: api-server (via scripts/dev-api.mjs), mobile (via scripts/dev-*.mjs)
#
#   cp .env.example .env
#   # fill in secrets, then:
#   pnpm db:up
#   pnpm dev:api       # terminal 1
#   pnpm dev:android   # terminal 2 (dev client — recommended)
# =============================================================================

# ── Database (local Docker — see docker-compose.yml) ─────────────────────────
DATABASE_URL=postgresql://rubai:rubai_dev_password@localhost:5432/rubai

# ── API server ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# Supabase Auth — https://supabase.com/dashboard → Project → Settings → API
# JWT Secret: Settings → API → JWT Settings → JWT Secret
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# OpenAI — platform.openai.com → API keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# Optional Anthropic failover (recommended for production)
# ANTHROPIC_API_KEY=sk-ant-...

# RevenueCat — app.revenuecat.com → Project → API keys (V2 secret for server)
REVENUECAT_V2_SECRET_KEY=sk_...
# Webhook secret (required in production)
# REVENUECAT_WEBHOOK_SECRET=whsec_...

# Optional admin support dashboard
# ADMIN_API_KEY=your-internal-admin-key

# ── Mobile (Expo) — also read from root .env by dev-*.mjs ────────────────────
# Local API URL — REQUIRED when testing on a physical phone (use your PC LAN IP)
# EXPO_PUBLIC_API_URL=http://192.168.1.10:5000
# Emulator: use http://10.0.2.2:5000 or adb reverse + localhost
EXPO_PUBLIC_API_URL=http://localhost:5000

# RevenueCat — Public app-specific keys
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=test_...
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_...

# Expo dev server port
EXPO_PORT=8081
