    "dev:api": "node scripts/dev-api.mjs",
    "dev:mobile": "node scripts/dev-mobile.mjs",
    "dev:android": "node scripts/dev-android.mjs",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "verify:clerk": "node scripts/verify-supabase.mjs",
    "build:android:dev": "node scripts/build-android-dev.mjs",
    "run:android:local": "node scripts/run-android-local.mjs",
    "db:up": "node scripts/db-up.mjs",
    "db:down": "node scripts/db-down.mjs",
    "db:logs": "node scripts/db-logs.mjs"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
